---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="sticky top-0 z-50 bg-lacquer/90 backdrop-blur-md border-b border-gold/10 px-4 py-3">
	<nav class="max-w-6xl mx-auto flex items-center justify-between font-sans">
		<div class="flex items-center space-x-3">
			{/* Kinpaku Mark / Logo */}
			<div class="w-8 h-8 bg-gold flex items-center justify-center rounded-xs select-none">
				<span class="text-lacquer-deep font-bold text-lg leading-none">Ⅹ</span>
			</div>
			<h2>
				<a href="/" class="text-champagne font-display font-semibold tracking-wider text-xl hover:text-gold transition-colors">
					{SITE_TITLE}
				</a>
			</h2>
		</div>
		<div class="flex items-center space-x-6 text-sm text-text-warm font-medium">
			<HeaderLink href="/" class="hover:text-gold transition-colors py-1">Home / หน้าหลัก</HeaderLink>
			<HeaderLink href="/blog" class="hover:text-gold transition-colors py-1">Blog / บล็อก</HeaderLink>
			<HeaderLink href="/about" class="hover:text-gold transition-colors py-1">About / ประวัติ</HeaderLink>
			
			{/* Theme Selector */}
			<div class="relative inline-block text-left font-mono text-[10px]">
				<select id="theme-selector" class="bg-raised border border-gold/20 text-gold rounded-xs px-2 py-0.5 focus:outline-none focus:border-gold cursor-pointer" aria-label="Theme Selector">
					<option value="dark">Dark 🖤</option>
					<option value="light">Light 🍦</option>
					<option value="white">White ⚪</option>
				</select>
			</div>
			
			<a href="https://github.com/MEYD-605/no10-landing" target="_blank" class="text-text-muted hover:text-gold transition-colors p-1" aria-label="GitHub">
				<svg viewBox="0 0 16 16" aria-hidden="true" width="20" height="20" fill="currentColor">
					<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path>
				</svg>
			</a>
		</div>
	</nav>
</header>

<script is:inline>
	const select = document.getElementById('theme-selector');
	if (select) {
		const currentTheme = localStorage.getItem('theme') || 'dark';
		select.value = currentTheme;
		select.addEventListener('change', (e) => {
			const theme = e.target.value;
			document.documentElement.setAttribute('data-theme', theme);
			localStorage.setItem('theme', theme);
		});
	}
</script>

